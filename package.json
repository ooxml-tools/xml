{
  "name": "@ooxml-tools/xml",
  "description": "Some XML helpers to help with OOXML development",
  "version": "0.8.1",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/ooxml-tools/xml"
  },
  "scripts": {
    "lint": "pnpx prettier . --check",
    "test": "vitest run --coverage",
    "test:ci": "vitest run --coverage --reporter=junit --outputFile=test-report.junit.xml",
    "lint:format": "pnpx prettier . --write",
    "build": "rollup -c rollup.config.ts --configPlugin typescript"
  },
  "exports": {
    ".": {
      "import": {
        "default": "./dist/npm/es/index.js",
        "types": "./dist/npm/es/types.d.ts"
      },
      "require": {
        "default": "./dist/npm/cjs/index.js",
        "types": "./dist/npm/cjs/types.d.ts"
      }
    }
  },
  "files": [
    "./dist/npm",
    "./package.json",
    "./README.md"
  ],
  "devDependencies": {
    "@codecov/rollup-plugin": "^1.9.1",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-typescript": "^12.1.2",
    "@rollup/plugin-virtual": "^3.0.2",
    "@tsconfig/node22": "^22.0.0",
    "@types/yargs": "^17.0.32",
    "@vitest/coverage-v8": "^4.1.8",
    "prettier": "^3.8.3",
    "rollup": "^4.61.1",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-dts": "^6.1.1",
    "rollup-plugin-preserve-shebang": "^1.0.1",
    "rollup-plugin-typescript-paths": "^1.5.0",
    "ts-node": "^10.9.2",
    "tslib": "^2.6.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@11.2.0",
  "engines": {
    "node": ">=20.x",
    "pnpm": ">=11"
  },
  "dependencies": {
    "xml-js": "^1.6.11"
  }
}
